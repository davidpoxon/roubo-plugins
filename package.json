{
  "name": "roubo-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Source for the Roubo integration and component plugins, built against the published @roubo SDK packages.",
  "author": "David Poxon",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "workspaces": [
    "plugins/*"
  ],
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git rev-parse --git-dir',{stdio:'ignore'});require('child_process').execSync('git config core.hooksPath scripts/git-hooks',{stdio:'inherit'});require('fs').chmodSync('scripts/git-hooks/commit-msg',0o755)}catch{}\"",
    "build": "npm run build -w @roubo/shared-github && npm run build -w @roubo/plugin-github-com && npm run build -w @roubo/plugin-ghe && npm run build -w @roubo/plugin-jira-self-hosted && npm run build -w @roubo/plugin-process && npm run build -w @roubo/plugin-database",
    "release:pack": "node scripts/release/pack.mjs",
    "release:sign": "node scripts/release/sign-catalog.mjs",
    "release:sign-keyring": "node scripts/release/sign-key-ring.mjs",
    "release:verify-keyring": "node scripts/release/verify-keyring.mjs",
    "release:self-check": "node scripts/release/self-check.mjs",
    "test": "node --test \"scripts/release/**/*.test.mjs\"",
    "test:plugins": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
